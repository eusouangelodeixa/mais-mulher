# ──────────────────────────────────────────────────────────────
# +Mulher — variáveis de ambiente
# Copie este arquivo para `.env` e ajuste os valores.
# ──────────────────────────────────────────────────────────────

# Banco de dados (Postgres local via docker-compose).
# Em produção, troque por DATABASE_URL/DIRECT_URL do Supabase.
DATABASE_URL="postgresql://maismulher:maismulher@localhost:5433/maismulher?schema=public"
DIRECT_URL="postgresql://maismulher:maismulher@localhost:5433/maismulher?schema=public"

# Segredo para assinar a sessão (JWT). Gere um valor longo e aleatório.
AUTH_SECRET="troque-por-um-segredo-longo-e-aleatorio"

# Segredo que protege a rota de cron de lembretes.
CRON_SECRET="troque-por-um-segredo-de-cron"

# URL base do app (usada pelo cron local e pelos retornos de pagamento).
APP_BASE_URL="http://localhost:3000"

# ── Komunika (WhatsApp) ──
# Em modo mock, as mensagens/OTP são impressas no console do servidor.
# Para usar de verdade: KOMUNIKA_MOCK=false e preencha API key + instanceId.
KOMUNIKA_MOCK="true"
KOMUNIKA_BASE_URL="https://api.komunika.site"
KOMUNIKA_API_KEY=""
KOMUNIKA_INSTANCE_ID=""

# ── Lojou (pagamentos M-Pesa / E-mola) — fluxo pay-first ──
# A lead preenche Nome + WhatsApp em /comecar e é enviada ao checkout hospedado
# da Lojou. Após o pagamento, a Lojou chama o nosso webhook.
#
# Link de checkout hospedado da Lojou (o mesmo para todas as leads).
LOJOU_CHECKOUT_URL="https://pay.lojou.app/p/NvssZ"
# Token-segredo que protege a URL do webhook. Gere um valor longo e aleatório
# (ex.: `openssl rand -hex 24`). A URL completa do webhook aparece no painel /admin.
LOJOU_WEBHOOK_SECRET="troque-por-um-token-de-webhook-aleatorio"
# Valor mínimo (MT) para uma venda aprovada ser aceita (anti-forja). Padrão: 47.
LOJOU_MIN_AMOUNT_MT="47"

# ── Painel admin (/admin) ──
# Senha de acesso ao painel administrativo (leads, vendas e URL do webhook).
ADMIN_PASSWORD="troque-por-uma-senha-forte"
